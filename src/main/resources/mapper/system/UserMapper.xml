<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.system.UserMapper">

    <!-- 1. 结果映射配置（解决字段与属性命名不一致问题） -->
    <resultMap id="userResultMap" type="org.seaPack.model.system.User">
        <id property="id" column="id" />
        <result property="userName" column="user_name"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="mobile" column="mobile"/>
        <result property="nickName" column="nick_name"/>
        <result property="gender" column="gender"/>
        <result property="status" column="status"/>
        <result property="deptId" column="dept_id"/>
        <result property="deptName" column="dept_name"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 2. 动态条件查询（用户提供的核心代码） -->
    <select id="selectUserList" resultMap="userResultMap">
        SELECT
            id,
            user_name,
            password,
            email,
            mobile,
            nick_name,
            gender,
            status,
            dept_id,
            dept_name,
            DATE_FORMAT(create_time, '%Y-%m-%d %H:%i:%s') AS create_time
        FROM user
        <where>
            <if test="keywords != null and keywords != ''">
                AND (
                   user_name LIKE CONCAT('%', #{keywords}, '%')
                 OR nick_name LIKE CONCAT('%' #{keywords}, '%')
                 OR mobile = #{keywords}
                )
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="deptId != null and deptId != ''">
                AND dept_id = #{deptId}
            </if>
            <!-- 扩展：时间范围查询 -->
            <if test="startTime != null and startTime != '' and endTime != null and endTime != ''">
                AND DATE(create_time) BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据用户名查询用户（用于登录验证） -->
    <select id="selectUserByName" resultMap="userResultMap">
        SELECT id, user_name, password
        FROM user
        <where>
           <if test="userName != null and userName != ''">
               AND user_name = #{userName}
           </if>
        </where>
    </select>

    <!-- 根据 ID 查询用户 -->
    <select id="selectUserById" resultMap="userResultMap">
        SELECT id, user_name, mobile, nick_name, gender, email,
               status, dept_id, dept_name, create_time, password
        FROM user
        WHERE id = #{id}
    </select>

    <!-- 新增用户，插入所有业务字段 -->
    <insert id="insertUser" parameterType="org.seaPack.model.system.User"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (
            user_name, mobile, nick_name, gender, email,
            status, dept_id, dept_name, password, create_time
        ) VALUES (
            #{userName}, #{mobile}, #{nickName}, #{gender}, #{email},
            #{status}, #{deptId}, #{deptName}, #{password}, NOW()
        )
    </insert>

    <!-- 更新用户信息，只更新非空字段 -->
    <update id="updateUser" parameterType="org.seaPack.model.system.User">
        UPDATE user
        <set>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="mobile != null">mobile = #{mobile},</if>
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="email != null">email = #{email},</if>
            <if test="status != null">status = #{status},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="password != null">password = #{password},</if>
            create_time = #{createTime}
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据 ID 删除用户 -->
    <delete id="deleteUser" parameterType="java.lang.Long">
        DELETE FROM user WHERE id = #{id}
    </delete>

</mapper>