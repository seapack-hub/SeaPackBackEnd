<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.common.AlertLogMapper">

    <resultMap id="BaseResultMap" type="org.seaPack.model.common.AlertLog">
        <id column="id" jdbcType="BIGINT" property="id" />
        <result column="rule_id" jdbcType="BIGINT" property="ruleId" />
        <result column="triggered_rate" jdbcType="DECIMAL" property="triggeredRate" />
        <result column="triggered_price" jdbcType="DECIMAL" property="triggeredPrice" />
        <result column="sent_time" jdbcType="TIMESTAMP" property="sentTime" />
    </resultMap>

    <!-- 按用户 ID 查询告警日志，支持股票代码和时间范围筛选 -->
    <select id="selectLogsByUserId" resultMap="BaseResultMap">
        SELECT a.*
        FROM alert_log a
        JOIN monitor_threshold_config t ON a.rule_id = t.id
        JOIN user_stock_monitor m ON t.monitor_id = m.id
        <where>
            m.user_id = #{userId}
            <if test="stockCode != null and stockCode != ''">
                AND m.stock_code LIKE CONCAT('%', #{stockCode}, '%')
            </if>
            <if test="startTime != null and startTime != ''">
                AND a.sent_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND a.sent_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY a.sent_time DESC
    </select>

    <insert id="insertLog" parameterType="org.seaPack.model.common.AlertLog"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO alert_log (rule_id, triggered_rate, triggered_price, sent_time)
        VALUES (#{ruleId}, #{triggeredRate}, #{triggeredPrice}, NOW())
    </insert>

</mapper>
