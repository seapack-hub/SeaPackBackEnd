<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.ai.SkillModuleBindingMapper">

    <resultMap id="BaseMap" type="org.seaPack.model.ai.SkillModuleBinding">
        <id property="id" column="id"/>
        <result property="skillId" column="skill_id"/>
        <result property="moduleKey" column="module_key"/>
        <result property="position" column="position"/>
        <result property="config" column="config"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectBySkillId" resultMap="BaseMap">
        SELECT * FROM ai_skill_module_binding WHERE skill_id = #{skillId}
    </select>

    <select id="selectByModuleKey" resultMap="BaseMap">
        SELECT b.*, s.name AS skill_name, s.icon AS skill_icon, s.code AS skill_code
        FROM ai_skill_module_binding b
        INNER JOIN ai_skill s ON b.skill_id = s.id
        WHERE b.module_key = #{moduleKey}
        <if test="status != null">AND b.status = #{status}</if>
        ORDER BY s.sort_order ASC
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM ai_skill_module_binding WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="org.seaPack.model.ai.SkillModuleBinding"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_skill_module_binding (skill_id, module_key, position, config, status, created_at)
        VALUES (#{skillId}, #{moduleKey}, #{position}, #{config}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="org.seaPack.model.ai.SkillModuleBinding">
        UPDATE ai_skill_module_binding
        <set>
            <if test="moduleKey != null">module_key = #{moduleKey},</if>
            <if test="position != null">position = #{position},</if>
            <if test="config != null">config = #{config},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_skill_module_binding WHERE id = #{id}
    </delete>

    <delete id="deleteBySkillId">
        DELETE FROM ai_skill_module_binding WHERE skill_id = #{skillId}
    </delete>

</mapper>
