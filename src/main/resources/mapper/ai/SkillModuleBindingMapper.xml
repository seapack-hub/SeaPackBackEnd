<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.ai.SkillModuleBindingMapper">

    <resultMap id="BaseMap" type="org.seaPack.model.ai.SkillModuleBinding">
        <id property="id" column="id"/>
        <result property="skillId" column="skill_id"/>
        <result property="moduleKey" column="module_key"/>
        <result property="position" column="position"/>
        <result property="config" column="config"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectBySkillId" resultMap="BaseMap">
        SELECT * FROM ai_skill_module_binding WHERE skill_id = #{skillId}
    </select>

    <select id="selectByModuleKey" resultMap="BaseMap">
        SELECT b.*, s.name AS skill_name, s.icon AS skill_icon, s.code AS skill_code
        FROM ai_skill_module_binding b
        INNER JOIN ai_skill s ON b.skill_id = s.id
        WHERE b.module_key = #{moduleKey}
        <if test="status != null">AND b.status = #{status}</if>
        ORDER BY s.sort_order ASC
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM ai_skill_module_binding WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="org.seaPack.model.ai.SkillModuleBinding"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_skill_module_binding (skill_id, module_key, position, config, status, created_at)
        VALUES (#{skillId}, #{moduleKey}, #{position}, #{config}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="org.seaPack.model.ai.SkillModuleBinding">
        UPDATE ai_skill_module_binding
        <set>
            <if test="moduleKey != null">module_key = #{moduleKey},</if>
            <if test="position != null">position = #{position},</if>
            <if test="config != null">config = #{config},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_skill_module_binding WHERE id = #{id}
    </delete>

    <delete id="deleteBySkillId">
        DELETE FROM ai_skill_module_binding WHERE skill_id = #{skillId}
    </delete>

    <resultMap id="BindingVOMap" type="org.seaPack.dto.ai.SkillBindingVO">
        <id property="skillId" column="skill_id"/>
        <result property="skillName" column="skill_name"/>
        <result property="skillCode" column="skill_code"/>
        <result property="promptTemplate" column="prompt_template"/>
        <result property="outputFormat" column="output_format"/>
        <result property="inputSchema" column="input_schema"/>
        <result property="maxTokens" column="max_tokens"/>
        <result property="moduleKey" column="module_key"/>
        <result property="position" column="position"/>
        <result property="status" column="status"/>
        <result property="config" column="config"/>
        <collection property="params" ofType="org.seaPack.dto.ai.SkillBindingParamVO">
            <result property="paramName" column="param_name"/>
            <result property="label" column="label"/>
            <result property="paramType" column="param_type"/>
            <result property="required" column="required"/>
            <result property="options" column="options"/>
            <result property="placeholder" column="placeholder"/>
        </collection>
    </resultMap>

    <select id="selectBindingsWithDetails" resultMap="BindingVOMap">
        SELECT b.id,
               b.skill_id,
               b.module_key,
               b.position,
               b.status,
               b.config,
               s.name AS skill_name,
               s.code AS skill_code,
               s.prompt_template,
               s.output_format,
               s.input_schema,
               s.max_tokens,
               p.param_name,
               p.label,
               p.param_type,
               p.required,
               p.options,
               p.placeholder,
               p.sort_order
        FROM ai_skill_module_binding b
        INNER JOIN ai_skill s ON b.skill_id = s.id
        LEFT JOIN ai_skill_param p ON p.skill_id = s.id AND p.sort_order IS NOT NULL
        <where>
            b.status = 1
            AND s.status = 1
            <if test="moduleKey != null and moduleKey != ''">AND b.module_key = #{moduleKey}</if>
        </where>
        ORDER BY b.id, p.sort_order ASC
    </select>

</mapper>
