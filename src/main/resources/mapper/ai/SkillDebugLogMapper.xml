<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.ai.SkillDebugLogMapper">

    <resultMap id="BaseMap" type="org.seaPack.model.ai.SkillDebugLog">
        <id property="id" column="id"/>
        <result property="skillId" column="skill_id"/>
        <result property="skillName" column="skill_name"/>
        <result property="skillCode" column="skill_code"/>
        <result property="inputParams" column="input_params"/>
        <result property="userMessage" column="user_message"/>
        <result property="rawPromptTemplate" column="raw_prompt_template"/>
        <result property="renderedPrompt" column="rendered_prompt"/>
        <result property="llmRequestBody" column="llm_request_body"/>
        <result property="llmResponseBody" column="llm_response_body"/>
        <result property="llmModel" column="llm_model"/>
        <result property="tokensPrompt" column="tokens_prompt"/>
        <result property="tokensCompletion" column="tokens_completion"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="durationLlmMs" column="duration_llm_ms"/>
        <result property="outputResult" column="output_result"/>
        <result property="status" column="status"/>
        <result property="errorMessage" column="error_message"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectList" resultMap="BaseMap">
        SELECT id, skill_id, skill_name, skill_code, input_params, user_message,
               raw_prompt_template, rendered_prompt, llm_request_body, llm_response_body,
               llm_model, tokens_prompt, tokens_completion, duration_ms, duration_llm_ms,
               output_result, status, error_message, created_by, created_at
        FROM ai_skill_debug_log
        <where>
            <if test="skillId != null">AND skill_id = #{skillId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM ai_skill_debug_log WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="org.seaPack.model.ai.SkillDebugLog"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_skill_debug_log (skill_id, skill_name, skill_code,
                                        input_params, user_message, raw_prompt_template, rendered_prompt,
                                        llm_request_body, llm_response_body, llm_model,
                                        tokens_prompt, tokens_completion, duration_ms, duration_llm_ms,
                                        output_result, status, error_message, created_by, created_at)
        VALUES (#{skillId}, #{skillName}, #{skillCode},
                #{inputParams}, #{userMessage}, #{rawPromptTemplate}, #{renderedPrompt},
                #{llmRequestBody}, #{llmResponseBody}, #{llmModel},
                #{tokensPrompt}, #{tokensCompletion}, #{durationMs}, #{durationLlmMs},
                #{outputResult}, #{status}, #{errorMessage}, #{createdBy}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM ai_skill_debug_log WHERE id = #{id}
    </delete>

</mapper>
