<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.ai.SkillParamMapper">

    <resultMap id="BaseMap" type="org.seaPack.model.ai.SkillParam">
        <id property="id" column="id"/>
        <result property="skillId" column="skill_id"/>
        <result property="paramName" column="param_name"/>
        <result property="label" column="label"/>
        <result property="paramType" column="param_type"/>
        <result property="required" column="required"/>
        <result property="defaultValue" column="default_value"/>
        <result property="options" column="options"/>
        <result property="placeholder" column="placeholder"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectBySkillId" resultMap="BaseMap">
        SELECT id, skill_id, param_name, label, param_type, required, default_value,
               options, placeholder, sort_order, created_at, updated_at
        FROM ai_skill_param
        WHERE skill_id = #{skillId}
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM ai_skill_param WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="org.seaPack.model.ai.SkillParam"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_skill_param (skill_id, param_name, label, param_type, required,
                                     default_value, options, placeholder, sort_order, created_at)
        VALUES (#{skillId}, #{paramName}, #{label}, #{paramType}, #{required},
                #{defaultValue}, #{options}, #{placeholder}, #{sortOrder}, NOW())
    </insert>

    <update id="update" parameterType="org.seaPack.model.ai.SkillParam">
        UPDATE ai_skill_param
        <set>
            <if test="paramName != null">param_name = #{paramName},</if>
            <if test="label != null">label = #{label},</if>
            <if test="paramType != null">param_type = #{paramType},</if>
            <if test="required != null">required = #{required},</if>
            <if test="defaultValue != null">default_value = #{defaultValue},</if>
            <if test="options != null">options = #{options},</if>
            <if test="placeholder != null">placeholder = #{placeholder},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_skill_param WHERE id = #{id}
    </delete>

    <delete id="deleteBySkillId">
        DELETE FROM ai_skill_param WHERE skill_id = #{skillId}
    </delete>

</mapper>
