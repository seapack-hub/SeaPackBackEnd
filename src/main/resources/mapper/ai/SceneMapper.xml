<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.seaPack.mapper.ai.SceneMapper">

    <resultMap id="BaseMap" type="org.seaPack.model.ai.Scene">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="icon" column="icon"/>
        <result property="coverColor" column="cover_color"/>
        <result property="description" column="description"/>
        <result property="isPublic" column="is_public"/>
        <result property="status" column="status"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="useCount" column="use_count"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectList" resultMap="BaseMap">
        SELECT id, name, code, icon, cover_color, description, is_public,
               status, sort_order, use_count, created_by, created_at, updated_at
        FROM ai_scene
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY sort_order ASC, created_at DESC
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM ai_scene WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseMap">
        SELECT * FROM ai_scene WHERE code = #{code}
    </select>

    <select id="countByCode" resultType="int">
        SELECT COUNT(*) FROM ai_scene WHERE code = #{code}
        <if test="excludeId != null">AND id != #{excludeId}</if>
    </select>

    <insert id="insert" parameterType="org.seaPack.model.ai.Scene"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_scene (name, code, icon, cover_color, description,
                              is_public, status, sort_order, use_count, created_by, created_at, updated_at)
        VALUES (#{name}, #{code}, #{icon}, #{coverColor}, #{description},
                #{isPublic}, #{status}, #{sortOrder}, 0, #{createdBy}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="org.seaPack.model.ai.Scene">
        UPDATE ai_scene
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="coverColor != null">cover_color = #{coverColor},</if>
            <if test="description != null">description = #{description},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            updated_at = NOW(),
        </set>
        WHERE id = #{id}
    </update>

    <update id="incrementUseCount">
        UPDATE ai_scene SET use_count = use_count + 1 WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_scene WHERE id = #{id}
    </delete>

</mapper>
